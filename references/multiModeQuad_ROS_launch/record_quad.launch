<?xml version="1.0"?>
<launch>
  <!--
    record_quad.launch - 数据记录与回放启动文件
    用于记录仿真数据并后续分析
  -->

  <arg name="namespace" default="quad"/>
  <arg name="bag_name"   default="$(env HOME)/quad_flight_$(env ROS_TIME).bag"/>

  <!-- 启动四旋翼 -->
  <include file="$(find multimodequad_ros)/launch/single_quad.launch">
    <arg name="namespace" value="$(arg namespace)"/>
  </include>

  <!-- 记录所有话题到 bag 文件 -->
  <node name="rosbag_record" pkg="rosbag" type="record"
        args="record -o $(arg bag_name)
              /$(arg namespace)/pose
              /$(arg namespace)/imuData
              /$(arg namespace)/flight_mode
              /$(arg namespace)/setpoint_velocity/cmd_vel_unstamped
              /$(arg namespace)/setpoint_attitude/attitude
              /$(arg namespace)/setpoint_attitude/cmd_vel
              /$(arg namespace)/thrust"/>
</launch>
